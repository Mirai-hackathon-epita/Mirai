# ─── Mira environment ───────────────────────────────────────────────
# Copy to .env and fill in. The app degrades gracefully when these are
# absent (in-memory store + seeded AI responses), so the demo never crashes.

# Cloud Temple LLMaaS (sovereign AI, OpenAI-compatible API serving Mistral).
# Docs: https://docs.cloud-temple.com/llmaas
CLOUD_TEMPLE_API_KEY=
CLOUD_TEMPLE_BASE_URL=https://api.ai.cloud-temple.com/v1
# Text/generation/planning/grading model (Mistral Small).
CLOUD_TEMPLE_MODEL=mistral-small
# Vision-capable model used for OCR of handwritten math. Falls back to
# CLOUD_TEMPLE_MODEL if unset. Confirm a vision model on the /models endpoint.
CLOUD_TEMPLE_VISION_MODEL=

# Redis (Scalingo managed addon). When unset, Mira uses an in-memory store
# that is seeded on boot — fine for local dev and a single-instance demo.
REDIS_URL=

# Optional: set to "1" to force the seeded/offline AI path even when a key
# is present (useful for rehearsing the demo without network dependency).
MIRA_OFFLINE=
